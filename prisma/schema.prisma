generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id                       String                    @id @default(cuid())
  name                     String
  code                     String                    @unique
  country                  String?
  city                     String?
  timezone                 String                    @default("Asia/Riyadh")
  logoUrl                  String?
  subscriptionPlan         String                    @default("trial")
  isActive                 Boolean                   @default(true)
  currency                 String                    @default("SAR")
  language                 String                    @default("EN-AR")
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  deletedAt                DateTime?
  employees                Employee[]
  employeeTransferRequests EmployeeTransferRequest[]
  projects                 Project[]
  roles                    Role[]
  users                    User[]
}

model Project {
  id                           String                     @id @default(cuid())
  companyId                    String
  code                         String
  name                         String
  location                     String?
  description                  String?
  isActive                     Boolean                    @default(true)
  createdById                  String?
  createdAt                    DateTime                   @default(now())
  updatedAt                    DateTime                   @updatedAt
  deletedAt                    DateTime?
  projectManagerId             String?
  employees                    Employee[]
  employeeTransferApprovals    EmployeeTransferApproval[] @relation("EmployeeTransferApprovalProject")
  employeeTransferRequestsFrom EmployeeTransferRequest[]  @relation("EmployeeTransferFromProject")
  employeeTransferRequestsTo   EmployeeTransferRequest[]  @relation("EmployeeTransferToProject")
  company                      Company                    @relation(fields: [companyId], references: [id])
  createdBy                    User?                      @relation("ProjectCreatedBy", fields: [createdById], references: [id])
  projectManager               User?                      @relation("ProjectManager", fields: [projectManagerId], references: [id])

  @@unique([companyId, code])
  @@index([companyId])
  @@index([projectManagerId])
}

model Role {
  id           String           @id @default(cuid())
  companyId    String?
  name         String
  description  String?
  isSystemRole Boolean          @default(false)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  company      Company?         @relation(fields: [companyId], references: [id])
  permissions  RolePermission[]
  users        User[]

  @@unique([companyId, name])
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  name        String
  description String?
  createdAt   DateTime         @default(now())
  roles       RolePermission[]
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  createdAt    DateTime   @default(now())
  permission   Permission @relation(fields: [permissionId], references: [id])
  role         Role       @relation(fields: [roleId], references: [id])

  @@unique([roleId, permissionId])
}

model User {
  id                         String                     @id @default(cuid())
  companyId                  String
  roleId                     String
  fullName                   String
  email                      String                     @unique
  phone                      String?
  passwordHash               String
  isActive                   Boolean                    @default(true)
  mustChangePassword         Boolean                    @default(false)
  lastLoginAt                DateTime?
  createdById                String?
  createdAt                  DateTime                   @default(now())
  updatedAt                  DateTime                   @updatedAt
  deletedAt                  DateTime?
  createdEmployees           Employee[]                 @relation("EmployeeCreatedBy")
  linkedEmployee             Employee?                  @relation("EmployeeLinkedUser")
  employeeTransferApprovals  EmployeeTransferApproval[] @relation("EmployeeTransferApprover")
  requestedEmployeeTransfers EmployeeTransferRequest[]  @relation("EmployeeTransferRequestedBy")
  createdProjects            Project[]                  @relation("ProjectCreatedBy")
  managedProjects            Project[]                  @relation("ProjectManager")
  refreshTokens              RefreshToken[]
  company                    Company                    @relation(fields: [companyId], references: [id])
  createdBy                  User?                      @relation("UserCreatedBy", fields: [createdById], references: [id])
  createdUsers               User[]                     @relation("UserCreatedBy")
  role                       Role                       @relation(fields: [roleId], references: [id])
}

model Employee {
  id               String                    @id @default(cuid())
  companyId        String
  employeeId       String
  name             String
  phone            String?
  email            String?
  jobTitle         String                    @default("Operator")
  status           EmployeeStatus            @default(ON_DUTY)
  projectId        String?
  linkedUserId     String?                   @unique
  createdById      String?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  deletedAt        DateTime?
  company          Company                   @relation(fields: [companyId], references: [id])
  createdBy        User?                     @relation("EmployeeCreatedBy", fields: [createdById], references: [id])
  linkedUser       User?                     @relation("EmployeeLinkedUser", fields: [linkedUserId], references: [id])
  project          Project?                  @relation(fields: [projectId], references: [id])
  transferRequests EmployeeTransferRequest[]

  @@unique([companyId, employeeId])
  @@index([companyId])
  @@index([projectId])
  @@index([status])
}

model EmployeeTransferRequest {
  id                String                     @id @default(cuid())
  companyId         String
  employeeId        String
  fromProjectId     String
  toProjectId       String
  requestedByUserId String
  status            EmployeeTransferStatus     @default(PENDING)
  reason            String?
  rejectionReason   String?
  approvedAt        DateTime?
  rejectedAt        DateTime?
  cancelledAt       DateTime?
  appliedAt         DateTime?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  approvals         EmployeeTransferApproval[]
  company           Company                    @relation(fields: [companyId], references: [id])
  employee          Employee                   @relation(fields: [employeeId], references: [id])
  fromProject       Project                    @relation("EmployeeTransferFromProject", fields: [fromProjectId], references: [id])
  requestedBy       User                       @relation("EmployeeTransferRequestedBy", fields: [requestedByUserId], references: [id])
  toProject         Project                    @relation("EmployeeTransferToProject", fields: [toProjectId], references: [id])

  @@index([companyId])
  @@index([employeeId])
  @@index([fromProjectId])
  @@index([toProjectId])
  @@index([requestedByUserId])
  @@index([status])
}

model EmployeeTransferApproval {
  id                String                         @id @default(cuid())
  transferRequestId String
  approverUserId    String
  projectId         String
  approvalStage     String
  status            EmployeeTransferApprovalStatus @default(PENDING)
  note              String?
  reviewedAt        DateTime?
  createdAt         DateTime                       @default(now())
  updatedAt         DateTime                       @updatedAt
  approver          User                           @relation("EmployeeTransferApprover", fields: [approverUserId], references: [id])
  project           Project                        @relation("EmployeeTransferApprovalProject", fields: [projectId], references: [id])
  transferRequest   EmployeeTransferRequest        @relation(fields: [transferRequestId], references: [id])

  @@unique([transferRequestId, approverUserId, projectId])
  @@index([transferRequestId])
  @@index([approverUserId])
  @@index([projectId])
  @@index([status])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])
}

enum EmployeeStatus {
  ON_DUTY
  VACATION
  RETIRED_RESIGNED
}

enum EmployeeTransferStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  APPLIED
  PARTIALLY_APPROVED
}

enum EmployeeTransferApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}
