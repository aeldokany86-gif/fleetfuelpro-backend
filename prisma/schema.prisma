generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // directUrl = env("DIRECT_URL")
}

model Company {
  id                       String                     @id @default(cuid())
  name                     String
  code                     String                     @unique
  country                  String?
  city                     String?
  timezone                 String                     @default("Asia/Riyadh")
  logoUrl                  String?
  subscriptionPlan         String                     @default("trial")
  isActive                 Boolean                    @default(true)
  currency                 String                     @default("SAR")
  language                 String                     @default("EN-AR")
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt
  deletedAt                DateTime?
  assets                   Asset[]
  assetTransferRequests    AssetTransferRequest[]
  assetAssignmentHistory   AssetAssignmentHistory[]
  stations                 Station[]
  stationTransferRequests  StationTransferRequest[]
  stationAssignmentHistory StationAssignmentHistory[]
  stationStockMovements    StationStockMovement[]
  projectFuelPriceHistory  ProjectFuelPriceHistory[]
  employees                Employee[]
  employeeTransferRequests EmployeeTransferRequest[]
  projects                 Project[]
  roles                    Role[]
  users                    User[]
}

model Project {
  id                           String                     @id @default(cuid())
  companyId                    String
  code                         String
  name                         String
  location                     String?
  description                  String?
  isActive                     Boolean                    @default(true)
  currentFuelPrice             Float                      @default(0)
  fuelPriceCurrency            String                     @default("SAR")
  fuelPriceEffectiveFrom       DateTime?
  createdById                  String?
  createdAt                    DateTime                   @default(now())
  updatedAt                    DateTime                   @updatedAt
  deletedAt                    DateTime?
  projectManagerId             String?
  assetTransferApprovals       AssetTransferApproval[]    @relation("AssetTransferApprovalProject")
  stationTransferApprovals     StationTransferApproval[]  @relation("StationTransferApprovalProject")
  assetTransferRequestsFrom    AssetTransferRequest[]     @relation("AssetTransferFromProject")
  stationTransferRequestsFrom  StationTransferRequest[]   @relation("StationTransferFromProject")
  assetTransferRequestsTo      AssetTransferRequest[]     @relation("AssetTransferToProject")
  stationTransferRequestsTo    StationTransferRequest[]   @relation("StationTransferToProject")
  assetAssignmentHistoryFrom   AssetAssignmentHistory[]   @relation("AssetAssignmentFromProject")
  stationAssignmentHistoryFrom StationAssignmentHistory[] @relation("StationAssignmentFromProject")
  assetAssignmentHistoryTo     AssetAssignmentHistory[]   @relation("AssetAssignmentToProject")
  stationAssignmentHistoryTo   StationAssignmentHistory[] @relation("StationAssignmentToProject")
  assets                       Asset[]
  stations                     Station[]
  employees                    Employee[]
  fuelPriceHistory             ProjectFuelPriceHistory[]
  employeeTransferApprovals    EmployeeTransferApproval[] @relation("EmployeeTransferApprovalProject")
  employeeTransferRequestsFrom EmployeeTransferRequest[]  @relation("EmployeeTransferFromProject")
  employeeTransferRequestsTo   EmployeeTransferRequest[]  @relation("EmployeeTransferToProject")
  company                      Company                    @relation(fields: [companyId], references: [id])
  createdBy                    User?                      @relation("ProjectCreatedBy", fields: [createdById], references: [id])
  projectManager               User?                      @relation("ProjectManager", fields: [projectManagerId], references: [id])

  @@unique([companyId, code])
  @@index([companyId])
  @@index([projectManagerId])
}

model Role {
  id           String           @id @default(cuid())
  companyId    String?
  name         String
  description  String?
  isSystemRole Boolean          @default(false)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  company      Company?         @relation(fields: [companyId], references: [id])
  permissions  RolePermission[]
  users        User[]

  @@unique([companyId, name])
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  name        String
  description String?
  createdAt   DateTime         @default(now())
  roles       RolePermission[]
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  createdAt    DateTime   @default(now())
  permission   Permission @relation(fields: [permissionId], references: [id])
  role         Role       @relation(fields: [roleId], references: [id])

  @@unique([roleId, permissionId])
}

model User {
  id                         String                     @id @default(cuid())
  companyId                  String
  roleId                     String
  fullName                   String
  employeeId                 String?
  username                   String?                    @unique
  email                      String?                    @unique
  phone                      String?
  passwordHash               String
  isActive                   Boolean                    @default(true)
  mustChangePassword         Boolean                    @default(false)
  lastLoginAt                DateTime?
  createdById                String?
  createdAt                  DateTime                   @default(now())
  updatedAt                  DateTime                   @updatedAt
  deletedAt                  DateTime?
  assetOdometerResets        AssetOdometerReset[]
  stationCounterResets       StationCounterReset[]
  stationStockMovements      StationStockMovement[]
  projectFuelPriceHistory    ProjectFuelPriceHistory[]
  assetTransferApprovals     AssetTransferApproval[]    @relation("AssetTransferApprover")
  stationTransferApprovals   StationTransferApproval[]  @relation("StationTransferApprover")
  assetAssignmentHistory     AssetAssignmentHistory[]   @relation("AssetAssignmentAssignedBy")
  stationAssignmentHistory   StationAssignmentHistory[] @relation("StationAssignmentAssignedBy")
  createdAssets              Asset[]                    @relation("AssetCreatedBy")
  createdStations            Station[]                  @relation("StationCreatedBy")
  requestedAssetTransfers    AssetTransferRequest[]     @relation("AssetTransferRequestedBy")
  requestedStationTransfers  StationTransferRequest[]   @relation("StationTransferRequestedBy")
  createdEmployees           Employee[]                 @relation("EmployeeCreatedBy")
  linkedEmployee             Employee?                  @relation("EmployeeLinkedUser")
  employeeTransferApprovals  EmployeeTransferApproval[] @relation("EmployeeTransferApprover")
  requestedEmployeeTransfers EmployeeTransferRequest[]  @relation("EmployeeTransferRequestedBy")
  createdProjects            Project[]                  @relation("ProjectCreatedBy")
  managedProjects            Project[]                  @relation("ProjectManager")
  refreshTokens              RefreshToken[]
  company                    Company                    @relation(fields: [companyId], references: [id])
  createdBy                  User?                      @relation("UserCreatedBy", fields: [createdById], references: [id])
  createdUsers               User[]                     @relation("UserCreatedBy")
  role                       Role                       @relation(fields: [roleId], references: [id])

  @@unique([companyId, employeeId])
  @@index([companyId])
  @@index([roleId])
  @@index([employeeId])
  @@index([username])
}

model Employee {
  id               String                    @id @default(cuid())
  companyId        String
  employeeId       String
  name             String
  phone            String?
  email            String?
  jobTitle         String                    @default("Operator")
  status           EmployeeStatus            @default(ON_DUTY)
  projectId        String?
  linkedUserId     String?                   @unique
  createdById      String?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  deletedAt        DateTime?
  company          Company                   @relation(fields: [companyId], references: [id])
  createdBy        User?                     @relation("EmployeeCreatedBy", fields: [createdById], references: [id])
  linkedUser       User?                     @relation("EmployeeLinkedUser", fields: [linkedUserId], references: [id])
  project          Project?                  @relation(fields: [projectId], references: [id])
  transferRequests EmployeeTransferRequest[]

  @@unique([companyId, employeeId])
  @@index([companyId])
  @@index([projectId])
  @@index([status])
}

model EmployeeTransferRequest {
  id                String                     @id @default(cuid())
  companyId         String
  employeeId        String
  fromProjectId     String
  toProjectId       String
  requestedByUserId String
  status            EmployeeTransferStatus     @default(PENDING)
  reason            String?
  rejectionReason   String?
  approvedAt        DateTime?
  rejectedAt        DateTime?
  cancelledAt       DateTime?
  appliedAt         DateTime?
  effectiveDate     DateTime?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  approvals         EmployeeTransferApproval[]
  company           Company                    @relation(fields: [companyId], references: [id])
  employee          Employee                   @relation(fields: [employeeId], references: [id])
  fromProject       Project                    @relation("EmployeeTransferFromProject", fields: [fromProjectId], references: [id])
  requestedBy       User                       @relation("EmployeeTransferRequestedBy", fields: [requestedByUserId], references: [id])
  toProject         Project                    @relation("EmployeeTransferToProject", fields: [toProjectId], references: [id])

  @@index([companyId])
  @@index([employeeId])
  @@index([fromProjectId])
  @@index([toProjectId])
  @@index([requestedByUserId])
  @@index([status])
}

model EmployeeTransferApproval {
  id                String                         @id @default(cuid())
  transferRequestId String
  approverUserId    String
  projectId         String
  approvalStage     String
  status            EmployeeTransferApprovalStatus @default(PENDING)
  note              String?
  reviewedAt        DateTime?
  createdAt         DateTime                       @default(now())
  updatedAt         DateTime                       @updatedAt
  approver          User                           @relation("EmployeeTransferApprover", fields: [approverUserId], references: [id])
  project           Project                        @relation("EmployeeTransferApprovalProject", fields: [projectId], references: [id])
  transferRequest   EmployeeTransferRequest        @relation(fields: [transferRequestId], references: [id])

  @@unique([transferRequestId, approverUserId, projectId])
  @@index([transferRequestId])
  @@index([approverUserId])
  @@index([projectId])
  @@index([status])
}

model Asset {
  id                   String                   @id @default(cuid())
  companyId            String
  assetId              String
  type                 String
  category             String?
  fuelTankCapacity     Float?
  currentOdometer      Float                    @default(0)
  status               AssetStatus              @default(ACTIVE)
  projectId            String?
  createdById          String?
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  deletedAt            DateTime?
  company              Company                  @relation(fields: [companyId], references: [id])
  createdBy            User?                    @relation("AssetCreatedBy", fields: [createdById], references: [id])
  project              Project?                 @relation(fields: [projectId], references: [id])
  odometerResetHistory AssetOdometerReset[]
  assignmentHistory    AssetAssignmentHistory[]
  transferRequests     AssetTransferRequest[]

  @@unique([companyId, assetId])
  @@index([companyId])
  @@index([projectId])
  @@index([status])
}

model AssetOdometerReset {
  id              String   @id @default(cuid())
  assetId         String
  companyId       String
  oldOdometer     Float
  newOdometer     Float
  reason          String
  effectiveAt     DateTime @default(now())
  createdByUserId String?
  createdAt       DateTime @default(now())
  asset           Asset    @relation(fields: [assetId], references: [id])
  createdBy       User?    @relation(fields: [createdByUserId], references: [id])

  @@index([assetId])
  @@index([companyId])
  @@index([createdByUserId])
}

model AssetTransferRequest {
  id                String                   @id @default(cuid())
  companyId         String
  assetId           String
  fromProjectId     String
  toProjectId       String
  requestedByUserId String
  status            EmployeeTransferStatus   @default(PENDING)
  reason            String?
  rejectionReason   String?
  approvedAt        DateTime?
  rejectedAt        DateTime?
  cancelledAt       DateTime?
  appliedAt         DateTime?
  effectiveDate     DateTime?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  approvals         AssetTransferApproval[]
  assignmentHistory AssetAssignmentHistory[]
  asset             Asset                    @relation(fields: [assetId], references: [id])
  company           Company                  @relation(fields: [companyId], references: [id])
  fromProject       Project                  @relation("AssetTransferFromProject", fields: [fromProjectId], references: [id])
  requestedBy       User                     @relation("AssetTransferRequestedBy", fields: [requestedByUserId], references: [id])
  toProject         Project                  @relation("AssetTransferToProject", fields: [toProjectId], references: [id])

  @@index([companyId])
  @@index([assetId])
  @@index([fromProjectId])
  @@index([toProjectId])
  @@index([requestedByUserId])
  @@index([status])
}

model AssetTransferApproval {
  id                String                         @id @default(cuid())
  transferRequestId String
  approverUserId    String
  projectId         String
  approvalStage     String
  status            EmployeeTransferApprovalStatus @default(PENDING)
  note              String?
  reviewedAt        DateTime?
  createdAt         DateTime                       @default(now())
  updatedAt         DateTime                       @updatedAt
  approver          User                           @relation("AssetTransferApprover", fields: [approverUserId], references: [id])
  project           Project                        @relation("AssetTransferApprovalProject", fields: [projectId], references: [id])
  transferRequest   AssetTransferRequest           @relation(fields: [transferRequestId], references: [id])

  @@unique([transferRequestId, approverUserId, projectId])
  @@index([transferRequestId])
  @@index([approverUserId])
  @@index([projectId])
  @@index([status])
}

model AssetAssignmentHistory {
  id                String                @id @default(cuid())
  companyId         String
  assetId           String
  fromProjectId     String?
  toProjectId       String
  transferRequestId String?
  assignmentType    AssetAssignmentType
  reason            String?
  assignedAt        DateTime              @default(now())
  assignedByUserId  String?
  createdAt         DateTime              @default(now())
  asset             Asset                 @relation(fields: [assetId], references: [id])
  company           Company               @relation(fields: [companyId], references: [id])
  fromProject       Project?              @relation("AssetAssignmentFromProject", fields: [fromProjectId], references: [id])
  toProject         Project               @relation("AssetAssignmentToProject", fields: [toProjectId], references: [id])
  assignedBy        User?                 @relation("AssetAssignmentAssignedBy", fields: [assignedByUserId], references: [id])
  transferRequest   AssetTransferRequest? @relation(fields: [transferRequestId], references: [id])

  @@index([companyId])
  @@index([assetId])
  @@index([fromProjectId])
  @@index([toProjectId])
  @@index([transferRequestId])
  @@index([assignedByUserId])
  @@index([assignedAt])
}

enum AssetAssignmentType {
  INITIAL_ASSIGNMENT
  TRANSFER
}

enum AssetStatus {
  ACTIVE
  INACTIVE
}

model Station {
  id                  String                     @id @default(cuid())
  companyId           String
  stationId           String
  name                String?
  type                String?
  capacity            Float?
  openingBalance      Float                      @default(0)
  currentStock        Float                      @default(0)
  currentCounter      Float                      @default(0)
  status              StationStatus              @default(ACTIVE)
  projectId           String?
  createdById         String?
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  deletedAt           DateTime?
  company             Company                    @relation(fields: [companyId], references: [id])
  project             Project?                   @relation(fields: [projectId], references: [id])
  createdBy           User?                      @relation("StationCreatedBy", fields: [createdById], references: [id])
  counterResetHistory StationCounterReset[]
  stockMovements      StationStockMovement[]
  assignmentHistory   StationAssignmentHistory[]
  transferRequests    StationTransferRequest[]

  @@unique([companyId, stationId])
  @@index([companyId])
  @@index([projectId])
  @@index([status])
}

model StationCounterReset {
  id              String   @id @default(cuid())
  stationId       String
  companyId       String
  oldCounter      Float
  newCounter      Float
  reason          String
  effectiveAt     DateTime @default(now())
  createdByUserId String?
  createdAt       DateTime @default(now())
  station         Station  @relation(fields: [stationId], references: [id])
  createdBy       User?    @relation(fields: [createdByUserId], references: [id])

  @@index([stationId])
  @@index([companyId])
  @@index([createdByUserId])
}

model StationStockMovement {
  id              String                   @id @default(cuid())
  stationId       String
  companyId       String
  movementType    StationStockMovementType
  quantity        Float
  balanceBefore   Float
  balanceAfter    Float
  referenceType   String?
  referenceId     String?
  reason          String?
  movementAt      DateTime                 @default(now())
  createdByUserId String?
  createdAt       DateTime                 @default(now())
  station         Station                  @relation(fields: [stationId], references: [id])
  company         Company                  @relation(fields: [companyId], references: [id])
  createdBy       User?                    @relation(fields: [createdByUserId], references: [id])

  @@index([stationId])
  @@index([companyId])
  @@index([movementType])
  @@index([movementAt])
  @@index([referenceType, referenceId])
}

model ProjectFuelPriceHistory {
  id                String   @id @default(cuid())
  projectId         String
  companyId         String
  country           String?
  currency          String
  basePricePerLiter Float?
  transportCost     Float?
  pricePerLiter     Float
  effectiveFrom     DateTime
  reason            String?
  createdByUserId   String?
  createdAt         DateTime @default(now())
  project           Project  @relation(fields: [projectId], references: [id])
  company           Company  @relation(fields: [companyId], references: [id])
  createdBy         User?    @relation(fields: [createdByUserId], references: [id])

  @@index([projectId])
  @@index([companyId])
  @@index([country])
  @@index([effectiveFrom])
}

model StationTransferRequest {
  id                String                     @id @default(cuid())
  companyId         String
  stationId         String
  fromProjectId     String
  toProjectId       String
  requestedByUserId String
  status            StationTransferStatus      @default(PENDING)
  reason            String?
  rejectionReason   String?
  approvedAt        DateTime?
  rejectedAt        DateTime?
  cancelledAt       DateTime?
  appliedAt         DateTime?
  effectiveDate     DateTime?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  approvals         StationTransferApproval[]
  assignmentHistory StationAssignmentHistory[]
  station           Station                    @relation(fields: [stationId], references: [id])
  company           Company                    @relation(fields: [companyId], references: [id])
  fromProject       Project                    @relation("StationTransferFromProject", fields: [fromProjectId], references: [id])
  toProject         Project                    @relation("StationTransferToProject", fields: [toProjectId], references: [id])
  requestedBy       User                       @relation("StationTransferRequestedBy", fields: [requestedByUserId], references: [id])

  @@index([companyId])
  @@index([stationId])
  @@index([fromProjectId])
  @@index([toProjectId])
  @@index([requestedByUserId])
  @@index([status])
}

model StationTransferApproval {
  id                String                        @id @default(cuid())
  transferRequestId String
  approverUserId    String
  projectId         String
  approvalStage     String
  status            StationTransferApprovalStatus @default(PENDING)
  note              String?
  reviewedAt        DateTime?
  createdAt         DateTime                      @default(now())
  updatedAt         DateTime                      @updatedAt
  approver          User                          @relation("StationTransferApprover", fields: [approverUserId], references: [id])
  project           Project                       @relation("StationTransferApprovalProject", fields: [projectId], references: [id])
  transferRequest   StationTransferRequest        @relation(fields: [transferRequestId], references: [id])

  @@unique([transferRequestId, approverUserId, projectId])
  @@index([transferRequestId])
  @@index([approverUserId])
  @@index([projectId])
  @@index([status])
}

model StationAssignmentHistory {
  id                String                  @id @default(cuid())
  companyId         String
  stationId         String
  fromProjectId     String?
  toProjectId       String
  transferRequestId String?
  assignmentType    StationAssignmentType
  reason            String?
  assignedAt        DateTime                @default(now())
  assignedByUserId  String?
  createdAt         DateTime                @default(now())
  station           Station                 @relation(fields: [stationId], references: [id])
  company           Company                 @relation(fields: [companyId], references: [id])
  fromProject       Project?                @relation("StationAssignmentFromProject", fields: [fromProjectId], references: [id])
  toProject         Project                 @relation("StationAssignmentToProject", fields: [toProjectId], references: [id])
  assignedBy        User?                   @relation("StationAssignmentAssignedBy", fields: [assignedByUserId], references: [id])
  transferRequest   StationTransferRequest? @relation(fields: [transferRequestId], references: [id])

  @@index([companyId])
  @@index([stationId])
  @@index([fromProjectId])
  @@index([toProjectId])
  @@index([transferRequestId])
  @@index([assignedByUserId])
  @@index([assignedAt])
}

enum StationAssignmentType {
  INITIAL_ASSIGNMENT
  TRANSFER
}

enum StationStatus {
  ACTIVE
  INACTIVE
}

enum StationStockMovementType {
  OPENING_BALANCE
  ADJUSTMENT
  PHYSICAL_ADJUSTMENT
  ZERO_BALANCE
  DIRECT_REFUEL_OUT
  INTERNAL_TRANSFER_IN
  INTERNAL_TRANSFER_OUT
  EXTERNAL_SUPPLY_IN
  EXTERNAL_TRANSFER_IN
  EXTERNAL_TRANSFER_OUT
  COUNTER_CORRECTION
}

enum StationTransferStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  APPLIED
  PARTIALLY_APPROVED
}

enum StationTransferApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])
}

enum EmployeeStatus {
  ON_DUTY
  VACATION
  RETIRED_RESIGNED
}

enum EmployeeTransferStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  APPLIED
  PARTIALLY_APPROVED
}

enum EmployeeTransferApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}
